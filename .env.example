# Database (Prisma)
DATABASE_URL=

# Auth (better-auth)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=

# Google Sheets sync
# Option A (recommended): split credentials — copy these two fields from the
# service-account JSON downloaded from Google Cloud Console → IAM → Service
# Accounts → Keys → Add Key → JSON. Keep the \n escapes in the private key.
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
#
# Option B (legacy): paste the entire service-account JSON as one line into
# this single variable. Only used if the split vars above are unset.
# GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=
#
# Each workspace owner pastes their sheet URL in workspace settings and shares
# the sheet with the service-account email (shown in the settings panel) as Editor.

# Email (SMTP — used for workspace invitations)
# Supports any SMTP relay (Brevo, SendGrid, Mailgun, etc.)
# Port 587 = STARTTLS (default). Port 465 = direct TLS (set SMTP_SECURE=true or use port 465).
# Set SMTP_FROM or EMAIL_FROM for the sender address.
SMTP_HOST=
SMTP_PORT=587
# SMTP_SECURE=true   # Set to true for direct TLS (port 465). Omit for STARTTLS (port 587).
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Google Sheets realtime batching (optional)
# Batch window in milliseconds - how long to wait before flushing the queue (default: 30000 = 30s)
# GOOGLE_SHEETS_BATCH_WINDOW_MS=30000
#
# Max entries per batch - flush immediately when queue reaches this size (default: 100)
# GOOGLE_SHEETS_BATCH_MAX_SIZE=100

# ImageKit (profile picture uploads)
# Create a free account at https://imagekit.io, then copy these three values from
# Developer Options → API keys. The private key stays server-side only; the public
# key and URL endpoint are used on the client to perform the upload.
# Leave all three blank to disable the upload UI (users can still paste a URL).
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# Server warm-up (cold-start mitigation)
# Set to "true" to fire a silent GET /api/health on every app mount.
# Useful on serverless platforms (Vercel, Render) to pre-warm the DB connection.
# The call is fire-and-forget and never blocks rendering.
# Currently the warm-up always runs in production; this var is reserved for
# external cron pings (e.g. UptimeRobot → /api/health every 10 minutes).
# WARMUP_ON_MOUNT=true
