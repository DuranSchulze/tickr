{
  "manifest_version": 3,
  "name": "Clockify Timer",
  "version": "1.0.0",
  "description": "Quick time tracking from your browser side panel",
  "permissions": ["sidePanel", "storage", "activeTab", "tabs"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://flow-track-theta.vercel.app/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Clockify Timer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
